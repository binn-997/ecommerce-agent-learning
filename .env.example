# Gateway uses the first configured provider and fails over in this order.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-latest
DEEPSEEK_MODEL=deepseek-chat
OPENAI_MODEL=gpt-4.1-mini

# Local infrastructure
POSTGRES_DB=ecommerce_ai
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=local-only-change-me

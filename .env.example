# Amazon SP-API (current LWA flow; AWS SigV4 credentials are not required by this client)
LWA_CLIENT_ID=
LWA_CLIENT_SECRET=
LWA_REFRESH_TOKEN=
SPAPI_ENDPOINT=https://sellingpartnerapi-eu.amazon.com
SPAPI_MARKETPLACE_ID=A1PA6795UKMFR9
AMAZON_ADS_PROFILE_ID=

# Feishu/Lark
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CHAT_ID=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=
